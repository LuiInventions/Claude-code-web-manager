{
  "name": "claude-code-control-center",
  "version": "1.3.0",
  "private": true,
  "description": "Local control center for your PC, projects, and Claude Code — runs only on 127.0.0.1.",
  "author": {
    "name": "LT Digital Concepts",
    "email": "luisklee@proton.me"
  },
  "main": "build/electron/main.js",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "next build --experimental-build-mode compile",
    "start": "set NODE_ENV=production&& tsx server.ts",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bundle:server": "node build/scripts/bundle-server.mjs",
    "electron:dev": "npm run bundle:server && electron build/electron/main.js",
    "electron:build": "npm run build && npm run bundle:server && electron-builder --config build/electron-builder.yml --publish never"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "dotenv": "^17.4.2",
    "highlight.js": "^11.11.1",
    "linkedom": "^0.18.12",
    "lucide-react": "^1.21.0",
    "next": "^15.5.19",
    "node-pty": "^1.1.0",
    "openai": "^6.44.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "^15.5.19",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
