# Copy to .env.local and fill in. Single-user, localhost-only tool.

# --- Required: API keys (server-side only; never exposed to the browser) ---
OPENAI_API_KEY=sk-your-openai-key-here
CARTESIA_API_KEY=sk_car_your-cartesia-key-here

# --- Reasoning model for the prompt improver + session review ---
OPENAI_MODEL=gpt-5.4-mini

# --- Voice: Cartesia (speech-to-text + text-to-speech), German ---
CARTESIA_VERSION=2026-03-01
CARTESIA_TTS_MODEL=sonic-turbo
CARTESIA_STT_MODEL=ink-whisper
# Cartesia voice id (German). Default Sebastian – Orator. Settings lists voices.
CARTESIA_VOICE=b7187e84-fe22-4344-ba4a-bc013fcb533e
VOICE_LANGUAGE=de

# --- Folder whose direct subfolders are treated as projects ---
# Optional. Defaults to ./projects inside the app (self-contained, kept off the
# user's home dir). GitHub clones default to ./projects/github. Uncomment to
# point them elsewhere — use an absolute path.
# PROJECTS_DIR=C:\Users\you\projects
# GITHUB_DIR=C:\Users\you\projects\github

# --- Loopback bind. Do NOT change HOST to 0.0.0.0 ---
HOST=127.0.0.1
PORT=3100

# Optional: explicit path to the Claude Code CLI if it is not on PATH.
# CLAUDE_BIN=C:\Users\you\.local\bin\claude.exe
